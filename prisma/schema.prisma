generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              Int       @id @default(autoincrement())
  name            String
  email           String    @unique
  emailVerifiedAt DateTime? @map("email_verified_at")
  userId          Int       @unique @map("user_id")
  category        String    @unique
  level           Int?
  phone           String?   @unique
  isAdmin         Boolean   @default(false) @map("is_admin")
  password        String
  rememberToken   String?   @map("remember_token")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  dues            Due[]

  @@map("users")
}

model Setting {
  id                 Int       @id @default(autoincrement())
  tenure             String
  name               String
  logo               String?
  favicon            String?
  website            String?
  tagline            String?
  description        String?
  email              String?
  idName             String?   @map("id_name")
  phone              String?
  address            String?
  dueDeadline        DateTime? @map("due_deadline")
  dueAmount          Decimal   @map("due_amount") @db.Decimal(10, 2)
  isRegistrationOpen Boolean   @default(false) @map("is_registration_open")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@map("settings")
}

model Due {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  tenure    String
  amount    BigInt
  ref       String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenure])
  @@map("dues")
}

model PasswordReset {
  email     String
  token     String
  createdAt DateTime? @map("created_at")

  @@id([email, token])
  @@index([email])
  @@map("password_resets")
}
