# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dues_manager?schema=public"

# ─── Auth ────────────────────────────────────────────────────────────────────
# Secret used to sign JWT session tokens. Must be a long random string.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="replace-with-a-strong-random-secret"

# ─── App ─────────────────────────────────────────────────────────────────────
# Public display name shown throughout the UI
NEXT_PUBLIC_APP_NAME="Dues Manager"

# ─── Paystack (Payment Gateway) ───────────────────────────────────────────────
# Obtain keys at: https://dashboard.paystack.com/#/settings/developer
# Use test keys (sk_test_... / pk_test_...) for local development
PAYSTACK_SECRET_KEY=""
PAYSTACK_PUBLIC_KEY=""

# ─── Resend (Transactional Email) ─────────────────────────────────────────────
# API key from: https://resend.com/api-keys
RESEND_API_KEY=""
# A verified sender address configured in your Resend domain settings
EMAIL_FROM="Dues Manager <onboarding@resend.dev>"
